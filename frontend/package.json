    "test:registered-manager": "playwright test tests/02-registered-manager.spec.ts",
    "test:responsible-individual": "playwright test tests/03-responsible-individual.spec.ts",
    "test:director": "playwright test tests/04-director.spec.ts",
    "test:smoke": "playwright test --grep \"smoke\"",
    "test:regression": "playwright test --grep \"regression\"",
    "pretest:e2e": "cd ../backend && NODE_ENV=test npx ts-node seeds/seedTestData.ts",
    "posttest:e2e": "playwright show-report"
  },
