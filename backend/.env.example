# ─── Ordin Core Backend Environment (EXAMPLE) ───────────────────────────────
# Copy to .env (development) or .env.production (production) and fill in real values.
# NEVER commit the populated files. Rotate any secret that was ever committed.

NODE_ENV=development
PORT=4000

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ordin_core
DB_USER=postgres
DB_PASSWORD=changeme
DB_SSL=false
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=10000

# ─── Auth (JWT) ──────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRE=15m
JWT_REFRESH_SECRET=replace-with-different-long-random-secret
JWT_REFRESH_EXPIRE=7d

# ─── Feature Flags & CORS ────────────────────────────────────────────────────
ENABLE_ENGINES=true
CORS_ORIGIN=http://localhost:5173

# ─── Redis (BullMQ / Socket.io) ──────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Email (SMTP) — used for password-reset links ────────────────────────────
# Any free SMTP provider works. If left blank, emails are logged to the console
# (dev fallback) instead of being sent.
#   Brevo (free 300/day): SMTP_HOST=smtp-relay.brevo.com  SMTP_PORT=587
#   Gmail (App Password): SMTP_HOST=smtp.gmail.com        SMTP_PORT=587
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=OrdinCore <no-reply@ordincore.local>

# Base URL of the frontend, used to build the password-reset link in the email.
APP_URL=http://localhost:5173
